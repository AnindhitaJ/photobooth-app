{
  "headers": [
    {
      "source": "/migrate-templates.html",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store"
        },
        {
          "key": "X-Robots-Tag",
          "value": "noindex, nofollow, noarchive"
        }
      ]
    },
    {
      "source": "/login",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate"
        },
        {
          "key": "X-Robots-Tag",
          "value": "noindex, nofollow, noarchive"
        }
      ]
    },
    {
      "source": "/template",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate"
        }
      ]
    },
    {
      "source": "/template.html",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate"
        }
      ]
    },
    {
      "source": "/login.html",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate"
        },
        {
          "key": "X-Robots-Tag",
          "value": "noindex, nofollow, noarchive"
        }
      ]
    },
    {
      "source": "/index.html",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate"
        }
      ]
    },
    {
      "source": "/auth.js",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate"
        }
      ]
    },
    {
      "source": "/config.js",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate"
        }
      ]
    },
    {
      "source": "/result.html",
      "headers": [
        {
          "key": "Cross-Origin-Opener-Policy",
          "value": "same-origin"
        },
        {
          "key": "Cross-Origin-Embedder-Policy",
          "value": "require-corp"
        }
      ]
    },
    {
      "source": "/sw.js",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate"
        },
        {
          "key": "Service-Worker-Allowed",
          "value": "/"
        }
      ]
    },
    {
      "source": "/manifest.json",
      "headers": [
        {
          "key": "Content-Type",
          "value": "application/manifest+json"
        },
        {
          "key": "Cache-Control",
          "value": "no-cache"
        }
      ]
    },
    {
      "source": "/app",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate"
        },
        {
          "key": "X-Robots-Tag",
          "value": "noindex, nofollow, noarchive"
        }
      ]
    },
    {
      "source": "/app.html",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate"
        },
        {
          "key": "X-Robots-Tag",
          "value": "noindex, nofollow, noarchive"
        }
      ]
    }
  ],
  "crons": [
    {
      "path": "/api/cleanup",
      "schedule": "0 0 * * *"
    }
  ],
  "rewrites": [
    {
      "source": "/about",
      "destination": "/about.html"
    },
    {
      "source": "/tutorial",
      "destination": "/tutorial.html"
    },
    {
      "source": "/content-sharing",
      "destination": "/content-sharing.html"
    },
    {
      "source": "/analytics",
      "destination": "/analytics.html"
    },
    {
      "source": "/detective-case",
      "destination": "/detective-case.html"
    },
    {
      "source": "/game-character",
      "destination": "/game-character.html"
    },
    {
      "source": "/certificate",
      "destination": "/certificate.html"
    },
    {
      "source": "/icon-portrait",
      "destination": "/icon-portrait.html"
    },
    {
      "source": "/trading-card",
      "destination": "/trading-card.html"
    },
    {
      "source": "/newspaper",
      "destination": "/newspaper.html"
    },
    {
      "source": "/magazine",
      "destination": "/magazine.html"
    },
    {
      "source": "/idcard",
      "destination": "/idcard.html"
    },
    {
      "source": "/reset-password",
      "destination": "/reset-password.html"
    },
    {
      "source": "/cms",
      "destination": "/cms.html"
    },
    {
      "source": "/event",
      "destination": "/event.html"
    },
    {
      "source": "/event-run",
      "destination": "/event-run.html"
    },
    {
      "source": "/login",
      "destination": "/login.html"
    },
    {
      "source": "/app",
      "destination": "/app.html"
    },
    {
      "source": "/template",
      "destination": "/template.html"
    },
    {
      "source": "/camera",
      "destination": "/camera.html"
    },
    {
      "source": "/filter",
      "destination": "/filter.html"
    },
    {
      "source": "/result",
      "destination": "/result.html"
    },
    {
      "source": "/preview",
      "destination": "/preview.html"
    },
    {
      "source": "/download",
      "destination": "/download.html"
    },
    {
      "source": "/gallery",
      "destination": "/gallery.html"
    },
    {
      "source": "/admin",
      "destination": "/admin.html"
    },
    {
      "source": "/ganci",
      "destination": "/ganci.html"
    },
    {
      "source": "/kalender",
      "destination": "/kalender.html"
    },
    {
      "source": "/migrate-templates",
      "destination": "/migrate-templates.html"
    }
  ],
  "redirects": [
    {
      "source": "/",
      "destination": "/login",
      "permanent": false
    },
    {
      "source": "/index.html",
      "destination": "/login",
      "permanent": false
    },
    {
      "source": "/app.html",
      "destination": "/app",
      "permanent": true
    },
    {
      "source": "/about.html",
      "destination": "/about",
      "permanent": true
    }
  ],
  "functions": {
    "api/migrate-templates.js": {
      "maxDuration": 60
    }
  }
}
